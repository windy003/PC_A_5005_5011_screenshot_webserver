# 服务器状态托盘监控 - 配置文件

# ===== 两个站点的完整状态 API 地址（含 http、IP、端口、路径）=====
# 对应系统托盘里的两个图标。留空的那个不会显示图标。
API_LARGE=http://192.168.2.56:5005/large/count_api
API_SMALL=http://192.168.2.56:5005/small/count_api

# ===== 数量字段名 =====
COUNT_FIELD=count

# ===== 轮询间隔（秒）=====
POLL_INTERVAL=60

# ===== （可选）托盘图标显示名称 =====
NAME_LARGE=大图
NAME_SMALL=小图
