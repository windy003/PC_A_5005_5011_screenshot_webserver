# 文件共享服务器配置文件（多站点合并版）
# 复制此文件为 .env 并修改配置

# ===== 两个站点的共享目录 =====
# Windows 路径可用反斜杠，含空格时建议用双引号包裹
# /small  站点对应的目录
Folder_Small=D:\shared\small

# /large  站点对应的目录
Folder_Large=D:\shared\large

# 登录用户名
USERNAME=admin

# 登录密码
PASSWORD=admin123

# 服务器端口（合并后两个站点共用一个端口）
PORT=5005

# 服务器主机（0.0.0.0 表示允许局域网访问，127.0.0.1 仅本机访问）
HOST=0.0.0.0

# 调试模式（生产环境设置为 False）
DEBUG=True

# 最大上传文件大小（MB）
MAX_UPLOAD_SIZE=500

# 会话密钥（可选，不设置会自动生成）
# SECRET_KEY=your-secret-key-here
