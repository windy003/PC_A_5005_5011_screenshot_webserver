# ====== 必填：要监控的两个源文件夹 ======
# Windows 路径直接写即可，可加引号也可不加
Source_Folder1=D:\path\to\folder1
Source_Folder2=D:\path\to\folder2

# ====== 可选：以下都有默认值，不需要可删掉 ======
# 每日筛选时 mtime 的年龄区间 [下界, 上界) 天（默认 3 ~ 4）
Range_Min_Days=3
Range_Max_Days=4
# 每天几点几分执行筛选+排定发布（默认 8:00）
Daily_Run_Hour=8
Daily_Run_Minute=0
# 发布总窗口小时数，间隔 = 窗口/文件数（默认 8，即 8:00~16:00）
Release_Window_Hours=8
# 主循环轮询间隔秒数（默认 60）
Poll_Interval_Seconds=60
